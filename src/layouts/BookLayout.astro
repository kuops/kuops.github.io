---
import { fade } from "astro:transitions";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import BookSidebar from "@/components/BookSidebar.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import ArticleEnhancements from "@/components/ArticleEnhancements.astro";
import type { SidebarGroup } from "@/books.config";

type Props = {
  title: string;
  description: string;
  bookSlug: string;
  sidebar: SidebarGroup[];
  currentSlug: string;
  titleMap?: Record<string, string>;
  headings: { depth: number; slug: string; text: string }[];
};

const {
  title,
  description,
  bookSlug,
  sidebar,
  currentSlug,
  titleMap = {},
  headings,
} = Astro.props;
---

<Layout title={title} description={description} scrollSmooth>
  <Header maxWidth="mx-auto w-full max-w-7xl px-4" />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12 pt-4" data-pagefind-body data-pagefind-filter="type:book" transition:animate={fade({ duration: "0.15s" })}>
    <div class="flex gap-8">
      <aside class="hidden w-56 flex-none lg:block">
        <div class="sticky top-24">
          <BookSidebar {bookSlug} {sidebar} {currentSlug} {titleMap} />
        </div>
      </aside>
      <div class="min-w-0 flex-1">
        <h1 class="mb-8 text-2xl font-bold text-accent sm:text-3xl" data-pagefind-meta="title">
          {title}
        </h1>
        <article
          id="article"
          class="app-prose w-full max-w-none prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
        >
          <slot />
        </article>
      </div>
      {headings.length > 0 && (
        <aside class="hidden w-52 flex-none xl:block">
          <div class="sticky top-24">
            <TableOfContents {headings} />
          </div>
        </aside>
      )}
    </div>
    <BackToTopButton />
  </main>
  <Footer maxWidth="mx-auto w-full max-w-7xl px-4" />
</Layout>

<ArticleEnhancements />
