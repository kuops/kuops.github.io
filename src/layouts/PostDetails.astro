---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import ArticleEnhancements from "@/components/ArticleEnhancements.astro";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
};

const { post, prevPost, nextPost } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content, headings: allHeadings } = await render(post);

const headings = allHeadings
  .filter(h => h.depth >= 2 && h.depth <= 4);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

---

<Layout {...layoutProps}>
  <Header maxWidth="mx-auto w-full max-w-5xl px-4" />
  <main
    id="main-content"
    class:list={["pb-12 mx-auto w-full max-w-5xl px-4"]}
    data-pagefind-body
    data-pagefind-filter="type:blog"
  >
    <BackButton />
    <div class="flex gap-8">
      <div class="min-w-0 flex-1">
        <h1
          transition:name={slugifyStr(title.replaceAll(".", "-"))}
          class="inline-block text-2xl font-bold text-accent sm:text-3xl"
        >
          {title}
        </h1>
        <div class="my-2 flex items-center gap-2">
          <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
          <span
            aria-hidden="true"
            class:list={[
              "max-sm:hidden",
              { hidden: !SITE.editPost.enabled || hideEditPost },
            ]}>|</span
          >
          <EditPost {hideEditPost} {post} class="max-sm:hidden" />
        </div>
        <article
          id="article"
          class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
        >
          <Content />
        </article>
      </div>
      {headings.length > 0 && (
        <aside class="hidden w-52 flex-none xl:block">
          <div class="sticky top-20">
            <TableOfContents {headings} />
          </div>
        </aside>
      )}
    </div>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous Post</span>
              <div class="text-sm text-accent/85">{prevPost.data.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next Post</span>
              <div class="text-sm text-accent/85">{nextPost.data.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer maxWidth="mx-auto w-full max-w-5xl px-4" />
</Layout>

<ArticleEnhancements />

<script>
  import mermaid from "mermaid";

  const mermaidSources: { el: HTMLElement; source: string }[] = [];

  function stripTheme(source: string) {
    return source.replace(/^---\n[\s\S]*?^---\n/m, (frontmatter) => {
      const cleaned = frontmatter.replace(/  theme:.*\n?/g, "");
      const inner = cleaned.replace(/^---\n?/, "").replace(/\n?---\n?$/, "").trim();
      if (!inner) return "";
      return `---\n${inner}\n---\n`;
    });
  }

  function initMermaidConfig() {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? "dark" : "default",
      themeVariables: isDark
        ? {
            primaryColor: "#c678dd",
            primaryTextColor: "#eaedf3",
            primaryBorderColor: "#3e4451",
            lineColor: "#abb2bf",
            secondaryColor: "#353c4d",
            tertiaryColor: "#2c313a",
            noteBkgColor: "#353c4d",
            noteTextColor: "#eaedf3",
            actorTextColor: "#eaedf3",
            actorBkgColor: "#353c4d",
            actorBorder: "#3e4451",
            labelTextColor: "#eaedf3",
            loopTextColor: "#eaedf3",
            sectionBkgColor: "#353c4d",
            altSectionBkgColor: "#2c313a",
            taskTextColor: "#eaedf3",
            taskBkgColor: "#c678dd",
            gridColor: "#3e4451",
            todayLineColor: "#e5c07b",
          }
        : {},
    });
  }

  async function renderMermaid() {
    const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
    if (mermaidBlocks.length === 0) return;

    initMermaidConfig();

    for (const pre of mermaidBlocks) {
      const code = pre.querySelector("code");
      const source = stripTheme(code?.textContent || "");
      const el = pre as HTMLElement;

      mermaidSources.push({ el, source });

      const id = "mermaid-" + Math.random().toString(36).slice(2);
      try {
        const { svg } = await mermaid.render(id, source);
        const container = document.createElement("div");
        container.className = "mermaid-svg overflow-x-auto";
        container.dataset.mermaidSource = source;
        container.innerHTML = svg;
        el.replaceWith(container);
      } catch {
        el.setAttribute("style", "color: red");
      } finally {
        document.getElementById("d" + id)?.remove();
      }
    }
  }

  async function rerenderMermaid() {
    const containers = document.querySelectorAll(".mermaid-svg[data-mermaid-source]");
    if (containers.length === 0) return;

    initMermaidConfig();

    for (const container of containers) {
      const source = (container as HTMLElement).dataset.mermaidSource || "";
      const id = "mermaid-" + Math.random().toString(36).slice(2);
      try {
        const { svg } = await mermaid.render(id, source);
        container.innerHTML = svg;
      } catch {
        // keep existing svg on error
      } finally {
        document.getElementById("d" + id)?.remove();
      }
    }
  }

  renderMermaid();
  document.addEventListener("astro:after-swap", renderMermaid);

  new MutationObserver(() => {
    rerenderMermaid();
  }).observe(document.documentElement, {
    attributeFilter: ["data-theme"],
  });
</script>
