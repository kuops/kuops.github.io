---
import { SITE } from "@/config";
import { useTranslations } from "@/i18n";

const t = useTranslations(SITE.lang);

const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");
const segments = currentUrlPath.split("/").slice(1);
const breadcrumbList: { label: string; href: string }[] = [];

if (segments[0] === "posts") {
  const pageNum = Number(segments[1]) || 1;
  if (pageNum === 1) {
    breadcrumbList.push({ label: t.nav.posts, href: "/posts/" });
  } else {
    breadcrumbList.push({
      label: `${t.nav.posts} (page ${pageNum})`,
      href: `/posts/${pageNum}/`,
    });
  }
} else if (segments[0] === "books" && segments.length > 1) {
  breadcrumbList.push({ label: t.nav.books, href: "/books/" });
  if (segments.length > 2) {
    const bookLabel = segments[1]
      .replace(/-/g, " ")
      .replace(/\b\w/g, c => c.toUpperCase());
    breadcrumbList.push({
      label: bookLabel,
      href: `/books/${segments[1]}/`,
    });
    if (segments.length > 3) {
      const groupLabel = segments[2]
        .replace(/-/g, " ")
        .replace(/\b\w/g, c => c.toUpperCase());
      breadcrumbList.push({
        label: groupLabel,
        href: `/books/${segments[1]}/${segments[2]}/`,
      });
      if (segments.length > 4) {
        breadcrumbList.push({
          label: decodeURIComponent(segments[3]),
          href: `/books/${segments[1]}/${segments[2]}/${segments[3]}/`,
        });
      }
    } else {
      breadcrumbList.push({
        label: decodeURIComponent(segments[2]),
        href: `/books/${segments[1]}/${segments[2]}/`,
      });
    }
  } else {
    breadcrumbList.push({
      label: segments[1]
        .replace(/-/g, " ")
        .replace(/\b\w/g, c => c.toUpperCase()),
      href: `/books/${segments[1]}/`,
    });
  }
} else if (segments[0] === "tags" && !isNaN(Number(segments[2]))) {
  const pageNum = Number(segments[2]);
  if (pageNum === 1) {
    breadcrumbList.push({
      label: segments[1],
      href: `/tags/${segments[1]}/`,
    });
  } else {
    breadcrumbList.push({
      label: `${segments[1]} (page ${pageNum})`,
      href: `/tags/${segments[1]}/${pageNum}/`,
    });
  }
} else {
  for (let i = 0; i < segments.length; i++) {
    const href = "/" + segments.slice(0, i + 1).join("/") + "/";
    breadcrumbList.push({ label: decodeURIComponent(segments[i]), href });
  }
}
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ol
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">{t.nav.home}</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((item, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {item.label}
            </span>
          </li>
        ) : (
          <li>
            <a href={item.href} class="capitalize opacity-70">
              {item.label}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ol>
</nav>
