---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

type Props = {
  headings: Heading[];
};

const { headings } = Astro.props;

const minDepth = headings.length > 0 ? Math.min(...headings.map(h => h.depth)) : 2;
---

<nav class="toc hidden xl:block" aria-label="Table of contents">
  <h2 class="mb-2 text-sm font-semibold uppercase tracking-wider text-foreground/60">
    目录
  </h2>
  <ul class="space-y-1 border-s-2 border-border text-sm">
    {headings.map(({ depth, slug, text }) => {
      const indent = depth - minDepth;
      return (
        <li
          class="toc-item"
          style={`padding-inline-start: ${indent * 0.75 + 0.75}rem`}
        >
          <a
            href={`#${slug}`}
            class="toc-link block truncate py-0.5 pe-2 text-foreground/60 transition-colors hover:text-accent"
            data-heading-slug={slug}
          >
            {text}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<script is:inline data-astro-rerun>
  function initTocHighlight() {
    const tocLinks = document.querySelectorAll(".toc-link");
    if (tocLinks.length === 0) return;

    const article = document.getElementById("article");
    if (!article) return;

    const headings = Array.from(
      article.querySelectorAll("h2, h3, h4, h5, h6")
    );

    function setActive() {
      let currentId = "";
      for (const heading of headings) {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= 120) {
          currentId = heading.id;
        }
      }

      tocLinks.forEach(link => {
        const slug = link.getAttribute("data-heading-slug");
        const li = link.closest(".toc-item");
        if (slug === currentId) {
          link.classList.remove("text-foreground/60");
          link.classList.add("text-accent", "font-medium");
          if (li) {
            li.classList.add("active");
          }
        } else {
          link.classList.add("text-foreground/60");
          link.classList.remove("text-accent", "font-medium");
          if (li) {
            li.classList.remove("active");
          }
        }
      });
    }

    window.addEventListener("scroll", setActive, { passive: true });
    setActive();
  }
  initTocHighlight();
</script>

<style>
  .toc-item.active {
    border-inline-start: 2px solid var(--accent);
  }
</style>
