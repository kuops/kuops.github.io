---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { useTranslations } from "@/i18n";
const t = useTranslations(SITE.lang);
---

<Layout title={`${t.nav.search} | ${SITE.title}`}>
  <Header />
  <main class="app-layout py-8">
    <p class="text-center text-foreground/60">
      {t.pages.searchHintBefore}
      <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 text-sm"
        >Ctrl+K</kbd
      >
      {t.pages.searchHintAfter}
    </p>
  </main>
  <Footer />
</Layout>

<script>
  const modal = document.querySelector("pagefind-modal");
  if (
    modal &&
    "open" in modal &&
    typeof (modal as { open: unknown }).open === "function"
  ) {
    const params = new URLSearchParams(window.location.search);
    const query = params.get("q");
    if (query) {
      (modal as { open: () => void }).open();
    }
  }
</script>
