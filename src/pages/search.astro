---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Search | ${SITE.title}`}>
  <Header />
  <main class="app-layout py-8">
    <p class="text-center text-foreground/60">
      点击右上角搜索图标或按 <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 text-sm">Ctrl+K</kbd> 打开搜索
    </p>
  </main>
  <Footer />
</Layout>

<script>
  const modal = document.querySelector("pagefind-modal");
  if (modal && "open" in modal && typeof (modal as Record<string, unknown>).open === "function") {
    const params = new URLSearchParams(window.location.search);
    const query = params.get("q");
    if (query) {
      (modal as Record<string, unknown>).open();
    }
  }
</script>
