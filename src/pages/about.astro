---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const about = await getEntry("pages", "about");

if (!about) {
  throw new Error("Missing content entry: `about.md` in `src/data/pages/`");
}

const { Content } = await render(about);
---

<Layout
  title={`${about.data.title} | ${SITE.title}`}
  description={about.data.description}
  ogImage={about.data.ogImage}
  canonicalURL={about.data.canonicalURL}
>
  <Header />

  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl font-semibold sm:text-3xl">{about.data.title}</h1>
      <Content />
    </section>
  </main>

  <Footer />
</Layout>
